{
  "permissions": {
    "allow": [
      "Bash(dir:*)",
      "Bash(npm install)",
      "Bash(npm run build:*)",
      "Bash(npm install:*)",
      "Bash(npm run dev:*)",
      "Bash(timeout:*)",
      "Bash(taskkill:*)",
      "Bash(gh workflow run:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "insforge",
    "docker-mcp"
  ]
}
