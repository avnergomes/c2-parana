# .env.example — copie para .env.local e preencha os valores reais

# Supabase
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe (chave publica - seguro para frontend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Sentry (opcional - para monitoramento de erros)
VITE_SENTRY_DSN=

# API de precos SIMA (opcional)
VITE_PRECOS_API_URL=https://sima-precos.onrender.com

# --------------------------------------------------
# TOKENS SENSIVEIS (NAO usar no frontend!)
# Configure estes apenas como GitHub Actions secrets
# para os ETLs server-side:
#
# SUPABASE_SERVICE_ROLE_KEY - chave de servico Supabase
# NASA_FIRMS_KEY - token NASA FIRMS para focos de calor
# WAQI_TOKEN - token AQICN para qualidade do ar
# --------------------------------------------------
