{
  "name": "c2-parana",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "etl:clima": "cd scripts && python etl_clima.py",
    "etl:noticias": "cd scripts && python etl_noticias.py",
    "etl:saude": "cd scripts && python etl_saude.py",
    "etl:ambiente": "cd scripts && python etl_ambiente.py",
    "etl:legislativo": "cd scripts && python etl_legislativo.py",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report"
  },
  "dependencies": {
    "@stripe/stripe-js": "^2.2.0",
    "@supabase/supabase-js": "^2.39.0",
    "@tanstack/react-query": "^5.17.0",
    "clsx": "^2.1.0",
    "d3": "^7.8.5",
    "date-fns": "^3.2.0",
    "ky": "^1.2.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.303.0",
    "pako": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.21.1",
    "recharts": "^2.10.3",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@types/d3": "^7.4.3",
    "@types/leaflet": "^1.9.8",
    "@types/pako": "^2.0.3",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.11",
    "vite-plugin-compression": "^0.5.1"
  }
